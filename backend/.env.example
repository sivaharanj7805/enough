# ── Database ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/enough
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── AI APIs ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (GA4 + GSC) ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# ── Email (Resend) ──
RESEND_API_KEY=re_...
EMAIL_FROM=Enough <reports@enough.app>

# ── App ──
SECRET_KEY=generate-with-python-secrets-token-hex-32
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Security ──
CRON_SECRET=generate-with-python-secrets-token-hex-16
ALLOWED_HOSTS=

# ── Monitoring (recommended in production) ──
SENTRY_DSN=https://...@sentry.io/...

# ── Required in production ──
# The following are enforced at startup (validate_production):
# - SECRET_KEY (must not be default)
# - SUPABASE_URL, SUPABASE_JWT_SECRET
# - STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_GROWTH
# - RESEND_API_KEY
# - OPENAI_API_KEY, ANTHROPIC_API_KEY
# - FRONTEND_URL, CRON_SECRET
